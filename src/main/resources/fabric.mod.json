{
  "schemaVersion": 1,
  "id": "spawnmanager",
  "version": "${version}",
  "name": "Spawn Manager",
  "description": "Server-side spawn protection and wilderness travel. Sets an exact world spawn with a circular protection zone where non-ops can't break blocks, open containers, use redstone, take damage, or set off explosions, and where hostile mobs won't spawn. Adds a /wild random-teleport command and moderator-placeable wild-portal regions.",
  "authors": ["Andrewwwwwwwwwwwwwww"],
  "license": "All Rights Reserved",
  "environment": "*",
  "entrypoints": {
    "main": ["io.github.andrewwwwwwwwwwwwwww.spawnmanager.SpawnManager"],
    "modmenu": ["io.github.andrewwwwwwwwwwwwwww.spawnmanager.client.ModMenuIntegration"]
  },
  "contact": {
    "homepage": "https://github.com/Andrewwwwwwwwwwwwwww/spawnmanager",
    "sources": "https://github.com/Andrewwwwwwwwwwwwwww/spawnmanager",
    "issues": "https://github.com/Andrewwwwwwwwwwwwwww/spawnmanager/issues"
  },
  "icon": "assets/spawnmanager/icon.png",
  "mixins": [
    "spawnmanager.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.19.2",
    "fabric-api": ">=0.148.2",
    "minecraft": "~26.1"
  },
  "recommends": {
    "modmenu": "*"
  }
}
